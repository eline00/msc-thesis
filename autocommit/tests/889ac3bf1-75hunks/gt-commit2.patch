+            var expected = new Simple_Options_WithExtraArgs {
+                    StringValue = "foo",
+                    ShortAndLong = "bar",
+                    BoolValue = true,
+                    LongValue = 256,
+                    IntSequence = Enumerable.Empty<int>(),
