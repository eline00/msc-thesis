+
+        [Fact]
+        public void Getopt_mode_can_have_EnableDashDash_expicitly_disabled()
+        {
+            // Arrange
+            var sut = new Parser(config => {
+                config.GetoptMode = true;
+                config.PosixlyCorrect = false;
